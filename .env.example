# Anthropic (console.anthropic.com -> API Keys)
ANTHROPIC_API_KEY=

# Supabase (supabase.com -> your project -> Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Strava (strava.com/settings/api)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Pool length in meters for swim SWOLF calc (default 22.86 = 25 yards)
# POOL_LENGTH_METERS=22.86
